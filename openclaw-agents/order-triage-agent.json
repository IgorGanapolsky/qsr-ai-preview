{
  "name": "qsr-order-triage-agent",
  "version": "1.0.0",
  "description": "Clarifies QSR orders, flags risky cases, and prepares manager handoff summaries.",
  "model": {
    "provider": "openai",
    "name": "gpt-4.1-mini",
    "temperature": 0.2
  },
  "inputs": {
    "type": "object",
    "required": ["customer_name", "items"],
    "properties": {
      "customer_name": {"type": "string"},
      "items": {"type": "array"},
      "pickup_time": {"type": "string"},
      "allergy_note": {"type": "string"},
      "channel": {"type": "string"}
    }
  },
  "instructions": [
    "Clarify missing menu modifiers.",
    "Suggest one relevant add-on only when helpful.",
    "Never guarantee allergy safety.",
    "Escalate refunds, illness, abuse, impossible pickup times, and catering-sized orders."
  ],
  "output_schema": {
    "type": "object",
    "properties": {
      "summary": {"type": "string"},
      "missing_fields": {"type": "array", "items": {"type": "string"}},
      "risk_flags": {"type": "array", "items": {"type": "string"}},
      "upsell": {"type": ["string", "null"]},
      "manager_question": {"type": "string"},
      "customer_reply": {"type": "string"}
    }
  }
}

